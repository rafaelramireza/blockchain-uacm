# =================================================================

# .gitignore para Tesis Blockchain UACM

# =================================================================

# --- [ 1. SEGURIDAD CRÍTICA: Identidades y Llaves ] ---

# Llaves privadas y material criptográfico sensible

**/*_sk
**/msp/keystore/*
**/users/*/msp/keystore/*
**/organizations/peerOrganizations/**/*.key
**/organizations/ordererOrganizations/**/*.key

# Certificados y archivos criptográficos adicionales

*.pem
*.crt
*.cert
*.key
*.jks

# Estructuras generadas por Fabric (se recrean)

organizations/peerOrganizations/
organizations/ordererOrganizations/
channel-artifacts/
system-genesis-block/

# --- [ 2. DEPENDENCIAS Y BUILD (GOLANG) ] ---

# Binarios y artefactos compilados

bin/
*.exe
*.dll
*.so
*.dylib
chaincode/*.test
__debug_bin

# Dependencias (no subir vendor)

vendor/
**/vendor/

# --- [ 3. DOCKER Y PERSISTENCIA ] ---

docker/volumes/
**/couchdb_data/
*.log
docker-compose.yaml.bak

# --- [ 4. HYPERLEDGER CALIPER ] ---

# Resultados y reportes de benchmarking

**/networktests/reports/
**/benchmarks/*/results/
caliper-log.txt

# Node.js (Caliper)

node_modules/

# (Se recomienda NO ignorar package-lock.json para reproducibilidad)

# --- [ 5. VARIABLES Y CONFIGURACIÓN LOCAL ] ---

.env
.env.*
*.env

# Configuración local de editores

.vscode/
.history/

# --- [ 6. SISTEMA ] ---

.DS_Store
Thumbs.db
*.bak
*.tmp
